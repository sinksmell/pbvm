#!/usr/bin/env bash
# pbvm — Protocol Buffers Version Manager
# Dispatches subcommands to libexec/pbvm-<cmd>.

set -euo pipefail

# Resolve the real directory of this script (follow symlinks).
_pbvm_resolve_self() {
  local src="$1"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" && pwd
}

_PBVM_BIN_DIR="$(_pbvm_resolve_self "${BASH_SOURCE[0]}")"
PBVM_PREFIX="${PBVM_PREFIX:-$(cd "$_PBVM_BIN_DIR/.." && pwd)}"
PBVM_LIBEXEC_DIR="${PBVM_LIBEXEC_DIR:-$PBVM_PREFIX/libexec}"
PBVM_LIB_DIR="${PBVM_LIB_DIR:-$PBVM_PREFIX/lib}"
PBVM_SHIMS_DIR="${PBVM_SHIMS_DIR:-$PBVM_PREFIX/shims}"

# Data root: where versions, archives, caches, and the active-version file live.
# Defaults to ~/.pbvm so a global install (PBVM_PREFIX=~/.pbvm) sees code and data
# in the same tree, matching the plan's layout. Dev layouts (checkout on another
# path) can override via PBVM_ROOT.
PBVM_ROOT="${PBVM_ROOT:-$HOME/.pbvm}"

export PBVM_PREFIX PBVM_LIBEXEC_DIR PBVM_LIB_DIR PBVM_SHIMS_DIR PBVM_ROOT

# Ensure data directories exist on every run (cheap).
mkdir -p "$PBVM_ROOT/versions" "$PBVM_ROOT/archives" "$PBVM_ROOT/cache"

# shellcheck source=../lib/log.sh
source "$PBVM_LIB_DIR/log.sh"

_pbvm_print_usage() {
  cat <<'EOF'
pbvm — Protocol Buffers Version Manager

Usage: pbvm <command> [<args>]

Commands:
  install <version>       Download and install a protoc version
  uninstall <version>     Remove an installed protoc version
  list                    List installed versions (active marked with =>)
  listall [--refresh]     List all versions available on GitHub Releases
  use <version>           Set the active protoc version (global)
  current                 Show the active protoc version and its path
  which                   Print the absolute path to the active protoc binary
  exec <version> -- <cmd> Run <cmd> with <version> as the active protoc
  version                 Print pbvm's own version
  help [<command>]        Show help (for a specific command, if given)

See https://github.com/<owner>/pbvm for documentation.
EOF
}

main() {
  if [[ $# -lt 1 ]]; then
    _pbvm_print_usage
    exit 1
  fi

  local cmd="$1"; shift
  case "$cmd" in
    -h|--help|help)
      exec "$PBVM_LIBEXEC_DIR/pbvm-help" "$@"
      ;;
    -v|--version)
      exec "$PBVM_LIBEXEC_DIR/pbvm-version" "$@"
      ;;
  esac

  local target="$PBVM_LIBEXEC_DIR/pbvm-$cmd"
  if [[ ! -x "$target" ]]; then
    log_error "unknown command: $cmd"
    echo >&2
    _pbvm_print_usage >&2
    exit 1
  fi

  exec "$target" "$@"
}

main "$@"
