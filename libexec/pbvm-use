#!/usr/bin/env bash
# usage: pbvm use [--global|--local] <version>
# Set the active protoc version.
#   --global (default)  write $PBVM_ROOT/version (applies system-wide)
#   --local             write ./.protoc-version (applies to this directory and its
#                       descendants; takes precedence over the global version)
# To set just the current shell, export PBVM_VERSION=<version> instead; that
# overrides both --local and --global.

set -euo pipefail

: "${PBVM_ROOT:?PBVM_ROOT not set — run via bin/pbvm}"
: "${PBVM_LIB_DIR:?PBVM_LIB_DIR not set — run via bin/pbvm}"

# shellcheck source=../lib/log.sh
source "$PBVM_LIB_DIR/log.sh"

scope="global"
version=""

for arg in "$@"; do
  case "$arg" in
    --global) scope="global" ;;
    --local)  scope="local" ;;
    --shell)
      log_error "--shell is not a flag; export PBVM_VERSION=<version> instead"
      exit 1
      ;;
    -h|--help)
      echo "usage: pbvm use [--global|--local] <version>"
      exit 0
      ;;
    -*)
      log_die "unknown flag: $arg"
      ;;
    *)
      if [[ -n "$version" ]]; then
        log_die "too many arguments"
      fi
      version="${arg#v}"
      ;;
  esac
done

[[ -n "$version" ]] || log_die "usage: pbvm use [--global|--local] <version>"

version_dir="$PBVM_ROOT/versions/protoc-$version"
if [[ ! -x "$version_dir/bin/protoc" ]]; then
  log_error "protoc $version is not installed"
  log_info "run 'pbvm install $version' first"
  exit 1
fi

case "$scope" in
  global)
    tmp="$(mktemp "$PBVM_ROOT/.version.XXXXXX")"
    printf '%s\n' "$version" > "$tmp"
    mv -f "$tmp" "$PBVM_ROOT/version"
    log_ok "now using protoc $version (global)"
    log_step "$version_dir/bin/protoc"
    ;;
  local)
    target="$PWD/.protoc-version"
    tmp="$(mktemp "$PWD/.protoc-version.XXXXXX")"
    printf '%s\n' "$version" > "$tmp"
    mv -f "$tmp" "$target"
    log_ok "now using protoc $version (local: $target)"
    log_step "$version_dir/bin/protoc"
    ;;
esac
